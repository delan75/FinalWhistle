@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<section class="hero-section text-white text-center py-5" style="background: linear-gradient(135deg, #0066CC 0%, #00A651 100%);">
    <div class="container py-5">
        <h1 class="display-3 fw-bold mb-3">⚽ COPA ELITE WORLD CUP 2026</h1>
        <p class="lead mb-4">The Ultimate 32-Nation Online Football Tournament</p>
        <p class="fs-5 mb-4">🗓️ Tournament Starts: <strong>April 1, 2026</strong></p>
        <div class="d-flex gap-3 justify-content-center">
            <a asp-controller="Account" asp-action="Register" class="btn btn-light btn-lg px-5">Register Now</a>
            <a href="#about" class="btn btn-outline-light btn-lg px-5">Learn More</a>
        </div>
    </div>
</section>

<!-- Stats Section -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="row text-center">
            <div class="col-md-3 mb-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h2 class="display-4 text-primary fw-bold">32</h2>
                        <p class="text-muted mb-0">National Teams</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h2 class="display-4 text-success fw-bold">80</h2>
                        <p class="text-muted mb-0">Total Matches</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h2 class="display-4 text-warning fw-bold">8</h2>
                        <p class="text-muted mb-0">Groups (A-H)</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h2 class="display-4 text-danger fw-bold">1</h2>
                        <p class="text-muted mb-0">Champion</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- About Section -->
<section id="about" class="py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4">
                <h2 class="display-5 fw-bold mb-4">About COPA ELITE 2026</h2>
                <p class="lead">Experience the thrill of international football competition in our premier online tournament.</p>
                <p>COPA ELITE WORLD CUP 2026 brings together 32 nations in an epic battle for glory. Follow your favorite teams, make predictions, and compete with fans worldwide.</p>
                <ul class="list-unstyled mt-4">
                    <li class="mb-2">✅ <strong>Group Stage:</strong> 48 matches across 8 groups</li>
                    <li class="mb-2">✅ <strong>Knockout Stage:</strong> Round of 16, Quarter-finals, Semi-finals</li>
                    <li class="mb-2">✅ <strong>Grand Final:</strong> Crown the champion</li>
                    <li class="mb-2">✅ <strong>Fan Predictions:</strong> Compete for leaderboard glory</li>
                </ul>
            </div>
            <div class="col-lg-6 mb-4">
                <div class="card border-0 shadow-lg">
                    <div class="card-body p-5 text-center">
                        <h3 class="mb-4">Tournament Format</h3>
                        <div class="mb-4">
                            <span class="badge bg-primary fs-5 px-4 py-2">Group Stage</span>
                            <p class="mt-2 text-muted">8 Groups × 4 Teams = 48 Matches</p>
                        </div>
                        <div class="mb-4">
                            <span class="badge bg-success fs-5 px-4 py-2">Round of 16</span>
                            <p class="mt-2 text-muted">16 Teams → 8 Winners</p>
                        </div>
                        <div class="mb-4">
                            <span class="badge bg-warning fs-5 px-4 py-2">Quarter-Finals</span>
                            <p class="mt-2 text-muted">8 Teams → 4 Winners</p>
                        </div>
                        <div class="mb-4">
                            <span class="badge bg-danger fs-5 px-4 py-2">Semi-Finals</span>
                            <p class="mt-2 text-muted">4 Teams → 2 Finalists</p>
                        </div>
                        <div>
                            <span class="badge bg-dark fs-5 px-4 py-2">🏆 Final</span>
                            <p class="mt-2 text-muted">2 Teams → 1 Champion</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features Section -->
<section class="py-5 bg-light">
    <div class="container">
        <h2 class="text-center display-5 fw-bold mb-5">Platform Features</h2>
        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center p-4">
                        <div class="mb-3">
                            <span class="fs-1">📊</span>
                        </div>
                        <h4>Live Standings</h4>
                        <p class="text-muted">Real-time group tables and knockout bracket updates</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center p-4">
                        <div class="mb-3">
                            <span class="fs-1">🎯</span>
                        </div>
                        <h4>Match Predictions</h4>
                        <p class="text-muted">Predict scores and compete on the leaderboard</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center p-4">
                        <div class="mb-3">
                            <span class="fs-1">🏅</span>
                        </div>
                        <h4>Team Profiles</h4>
                        <p class="text-muted">Detailed stats for all 32 teams and players</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="py-5 text-white" style="background: linear-gradient(135deg, #00A651 0%, #0066CC 100%);">
    <div class="container text-center py-5">
        <h2 class="display-5 fw-bold mb-4">Ready to Join the Action?</h2>
        <p class="lead mb-4">Register now to make predictions and compete with fans worldwide!</p>
        <a asp-controller="Account" asp-action="Register" class="btn btn-light btn-lg px-5">Create Your Account</a>
    </div>
</section>
