@model List<FinalWhistle.Application.Models.LeaderboardEntry>
@{
    ViewData["Title"] = "Leaderboard";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold" style="color: #0066CC;">
            <i class="bi bi-trophy-fill me-3" style="color: #FFD700;"></i>
            Leaderboard
        </h1>
        <p class="lead text-muted">Top Predictors - Global Rankings</p>
    </div>

    @if (Model.Any())
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="text-center" style="width: 80px;">Rank</th>
                                <th>User</th>
                                <th class="text-center" style="width: 100px;">Points</th>
                                <th class="text-center" style="width: 120px;">Predictions</th>
                                <th class="text-center" style="width: 100px;">Exact</th>
                                <th class="text-center" style="width: 100px;">Correct</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var entry in Model)
                            {
                                var isTopThree = entry.Rank <= 3;
                                var medalColor = entry.Rank == 1 ? "#FFD700" : entry.Rank == 2 ? "#C0C0C0" : entry.Rank == 3 ? "#CD7F32" : "";
                                var isCurrentUser = entry.UserId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

                                <tr class="@(isCurrentUser ? "table-primary" : "")">
                                    <td class="text-center">
                                        @if (isTopThree)
                                        {
                                            <span class="fs-4" style="color: @medalColor;">
                                                <i class="bi bi-trophy-fill"></i>
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="fw-bold">@entry.Rank</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="@(isCurrentUser ? "fw-bold" : "")">
                                            @entry.Username
                                            @if (isCurrentUser)
                                            {
                                                <span class="badge bg-primary ms-2">You</span>
                                            }
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-success fs-6">@entry.TotalPoints</span>
                                    </td>
                                    <td class="text-center">@entry.PredictionsCount</td>
                                    <td class="text-center">
                                        <span class="badge bg-warning text-dark">@entry.ExactScores</span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-info">@entry.CorrectResults</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="alert alert-info mt-4">
            <h6 class="mb-2"><i class="bi bi-info-circle me-2"></i>Ranking Criteria</h6>
            <ol class="mb-0 small">
                <li>Total Points (highest first)</li>
                <li>Number of Exact Scores (tiebreaker)</li>
                <li>Total Predictions (fewer is better)</li>
            </ol>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-5">
            <i class="bi bi-trophy fs-1 d-block mb-3"></i>
            <h4>No Rankings Yet</h4>
            <p class="mb-0">Be the first to make predictions and climb the leaderboard!</p>
        </div>
    }

    <div class="text-center mt-4">
        <a asp-controller="Predictions" asp-action="Index" class="btn btn-primary">
            <i class="bi bi-plus-circle me-2"></i>Make Predictions
        </a>
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-primary ms-2">
            <i class="bi bi-speedometer2 me-2"></i>My Dashboard
        </a>
    </div>
</div>

<style>
    .table tbody tr:hover {
        background-color: rgba(0, 102, 204, 0.05);
    }
</style>
