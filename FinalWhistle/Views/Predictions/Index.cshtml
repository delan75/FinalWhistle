@model List<FinalWhistle.Domain.Entities.Match>
@{
    ViewData["Title"] = "Make Predictions";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold" style="color: #0066CC;">Make Your Predictions</h1>
        <p class="lead text-muted">Predict match scores and earn points!</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-body bg-light">
            <h5 class="mb-3"><i class="bi bi-info-circle me-2"></i>How Points Work</h5>
            <div class="row">
                <div class="col-md-4">
                    <div class="text-center">
                        <div class="display-6 fw-bold" style="color: #FFD700;">3</div>
                        <small class="text-muted">Exact Score</small>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="text-center">
                        <div class="display-6 fw-bold" style="color: #00A651;">1</div>
                        <small class="text-muted">Correct Result</small>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="text-center">
                        <div class="display-6 fw-bold text-muted">0</div>
                        <small class="text-muted">Wrong Prediction</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="row g-4">
            @foreach (var match in Model)
            {
                var userPrediction = match.Predictions.FirstOrDefault();
                var hasKickoffSoon = match.KickoffTime <= DateTime.UtcNow.AddHours(1);

                <div class="col-lg-6">
                    <div class="card shadow-sm h-100 @(hasKickoffSoon ? "border-warning" : "")">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="badge bg-primary">@match.Stage</span>
                                @if (match.GroupId.HasValue)
                                {
                                    <span class="badge bg-secondary">Group @match.Group?.Name</span>
                                }
                                @if (hasKickoffSoon)
                                {
                                    <span class="badge bg-warning text-dark">
                                        <i class="bi bi-clock-fill me-1"></i>Closing Soon
                                    </span>
                                }
                            </div>

                            <div class="row align-items-center text-center mb-3">
                                <div class="col-5">
                                    <img src="@match.HomeTeam?.FlagUrl" alt="@match.HomeTeam?.Name" class="mb-2" style="width: 60px; height: 45px; object-fit: cover; border-radius: 6px;">
                                    <h6 class="fw-bold mb-0">@match.HomeTeam?.Name</h6>
                                </div>
                                <div class="col-2">
                                    <h5 class="text-muted mb-0">vs</h5>
                                </div>
                                <div class="col-5">
                                    <img src="@match.AwayTeam?.FlagUrl" alt="@match.AwayTeam?.Name" class="mb-2" style="width: 60px; height: 45px; object-fit: cover; border-radius: 6px;">
                                    <h6 class="fw-bold mb-0">@match.AwayTeam?.Name</h6>
                                </div>
                            </div>

                            <div class="text-center mb-3">
                                <small class="text-muted">
                                    <i class="bi bi-calendar3 me-1"></i>
                                    @match.KickoffTime.ToString("MMM dd, yyyy")
                                    <i class="bi bi-clock ms-2 me-1"></i>
                                    @match.KickoffTime.ToString("HH:mm")
                                </small>
                            </div>

                            <form asp-action="Submit" method="post">
                                <input type="hidden" name="matchId" value="@match.Id" />
                                <div class="row g-2">
                                    <div class="col-5">
                                        <input type="number" name="homeGoals" class="form-control text-center" 
                                               min="0" max="20" value="@(userPrediction?.PredictedHomeGoals ?? 0)" required>
                                    </div>
                                    <div class="col-2 text-center">
                                        <span class="d-block mt-2">-</span>
                                    </div>
                                    <div class="col-5">
                                        <input type="number" name="awayGoals" class="form-control text-center" 
                                               min="0" max="20" value="@(userPrediction?.PredictedAwayGoals ?? 0)" required>
                                    </div>
                                </div>
                                <button type="submit" class="btn btn-primary w-100 mt-3">
                                    <i class="bi bi-check-circle me-2"></i>
                                    @(userPrediction != null ? "Update Prediction" : "Submit Prediction")
                                </button>
                            </form>

                            @if (userPrediction != null)
                            {
                                <div class="alert alert-info mt-3 mb-0">
                                    <small>
                                        <i class="bi bi-info-circle me-1"></i>
                                        Last updated: @userPrediction.SubmittedAt.ToString("MMM dd, HH:mm")
                                    </small>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-5">
            <i class="bi bi-calendar-check fs-1 d-block mb-3"></i>
            <h4>No Upcoming Matches</h4>
            <p class="mb-0">Check back later for new matches to predict!</p>
        </div>
    }

    <div class="text-center mt-4">
        <a asp-action="MyPredictions" class="btn btn-outline-primary">
            <i class="bi bi-list-check me-2"></i>View My Predictions
        </a>
    </div>
</div>
