@model FinalWhistle.Domain.Entities.Match
@{
    ViewData["Title"] = "Schedule New Match";
}

<div class="container mt-4">
    <h2>Schedule New Match</h2>
    <hr />

    <form asp-action="Create" method="post">
        <input type="hidden" asp-for="TournamentId" value="@ViewBag.TournamentId" />
        
        <div class="row">
            <div class="col-md-6">
                <h5 class="mb-3">Match Details</h5>
                
                <div class="mb-3">
                    <label asp-for="Stage" class="form-label">Stage</label>
                    <select asp-for="Stage" class="form-select" asp-items="ViewBag.Stages"></select>
                    <span asp-validation-for="Stage" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="GroupId" class="form-label">Group (for Group Stage only)</label>
                    <select asp-for="GroupId" class="form-select" asp-items="ViewBag.Groups">
                        <option value="">-- Not Applicable --</option>
                    </select>
                    <span asp-validation-for="GroupId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="KickoffTime" class="form-label">Kickoff Date & Time</label>
                    <input asp-for="KickoffTime" class="form-control" type="datetime-local" />
                    <span asp-validation-for="KickoffTime" class="text-danger"></span>
                </div>
            </div>

            <div class="col-md-6">
                <h5 class="mb-3">Teams</h5>
                
                <div class="mb-3">
                    <label asp-for="HomeTeamId" class="form-label">Home Team</label>
                    <select asp-for="HomeTeamId" class="form-select" asp-items="ViewBag.Teams">
                        <option value="">-- Select Home Team --</option>
                    </select>
                    <span asp-validation-for="HomeTeamId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="AwayTeamId" class="form-label">Away Team</label>
                    <select asp-for="AwayTeamId" class="form-select" asp-items="ViewBag.Teams">
                        <option value="">-- Select Away Team --</option>
                    </select>
                    <span asp-validation-for="AwayTeamId" class="text-danger"></span>
                </div>

                <div class="alert alert-info">
                    <small>
                        <strong>Note:</strong> For knockout matches, you can leave teams as TBD and update them later when group stage completes.
                    </small>
                </div>
            </div>
        </div>

        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="mb-3">
            <button type="submit" class="btn btn-primary">Schedule Match</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
