@model FinalWhistle.Domain.Entities.Match
@{
    ViewData["Title"] = "Edit Match";
}

<div class="container mt-4">
    <h2>Edit Match</h2>
    <hr />

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="TournamentId" />
        
        <div class="row">
            <div class="col-md-6">
                <h5 class="mb-3">Match Details</h5>
                
                <div class="mb-3">
                    <label asp-for="Stage" class="form-label">Stage</label>
                    <select asp-for="Stage" class="form-select" asp-items="ViewBag.Stages"></select>
                    <span asp-validation-for="Stage" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="GroupId" class="form-label">Group</label>
                    <select asp-for="GroupId" class="form-select" asp-items="ViewBag.Groups">
                        <option value="">-- Not Applicable --</option>
                    </select>
                    <span asp-validation-for="GroupId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="KickoffTime" class="form-label">Kickoff Date & Time</label>
                    <input asp-for="KickoffTime" class="form-control" type="datetime-local" />
                    <span asp-validation-for="KickoffTime" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Status" class="form-label">Status</label>
                    <select asp-for="Status" class="form-select" asp-items="ViewBag.Statuses"></select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="IsLockedForPredictions" class="form-check-input" />
                    <label asp-for="IsLockedForPredictions" class="form-check-label">Lock Predictions</label>
                </div>
            </div>

            <div class="col-md-6">
                <h5 class="mb-3">Teams</h5>
                
                <div class="mb-3">
                    <label asp-for="HomeTeamId" class="form-label">Home Team</label>
                    <select asp-for="HomeTeamId" class="form-select" asp-items="ViewBag.Teams">
                        <option value="">-- TBD --</option>
                    </select>
                    <span asp-validation-for="HomeTeamId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="AwayTeamId" class="form-label">Away Team</label>
                    <select asp-for="AwayTeamId" class="form-select" asp-items="ViewBag.Teams">
                        <option value="">-- TBD --</option>
                    </select>
                    <span asp-validation-for="AwayTeamId" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="mb-3">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
