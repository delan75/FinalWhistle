@model FinalWhistle.Domain.Entities.Match
@{
    ViewData["Title"] = "Delete Match";
}

<div class="container mt-4">
    <h2>Delete Match</h2>
    <hr />

    <div class="alert alert-danger">
        <h4>Are you sure you want to delete this match?</h4>
        <p>This action cannot be undone. All predictions for this match will also be deleted.</p>
    </div>

    <div class="card">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Stage</dt>
                <dd class="col-sm-9">
                    <span class="badge bg-info">@Model.Stage</span>
                </dd>

                <dt class="col-sm-3">Match</dt>
                <dd class="col-sm-9">
                    <strong>@(Model.HomeTeam?.Name ?? "TBD") vs @(Model.AwayTeam?.Name ?? "TBD")</strong>
                </dd>

                <dt class="col-sm-3">Group</dt>
                <dd class="col-sm-9">@(Model.Group?.Name ?? "N/A")</dd>

                <dt class="col-sm-3">Kickoff Time</dt>
                <dd class="col-sm-9">@Model.KickoffTime.ToString("MMM dd, yyyy HH:mm")</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">
                    @switch (Model.Status)
                    {
                        case FinalWhistle.Domain.Enums.MatchStatus.Scheduled:
                            <span class="badge bg-secondary">Scheduled</span>
                            break;
                        case FinalWhistle.Domain.Enums.MatchStatus.Live:
                            <span class="badge bg-success">Live</span>
                            break;
                        case FinalWhistle.Domain.Enums.MatchStatus.Completed:
                            <span class="badge bg-dark">Completed</span>
                            break;
                    }
                </dd>
            </dl>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">Delete Match</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>
