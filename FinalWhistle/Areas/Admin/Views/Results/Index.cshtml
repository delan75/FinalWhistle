@model IEnumerable<FinalWhistle.Domain.Entities.Match>
@{
    ViewData["Title"] = "Match Results";
}

<div class="container mt-4">
    <h2>Match Results</h2>
    <p class="text-muted">Enter scores for completed matches</p>
    <hr />

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Stage</th>
                    <th>Match</th>
                    <th>Group</th>
                    <th>Status</th>
                    <th>Score</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var match in Model)
                {
                    <tr>
                        <td>
                            <small>@match.KickoffTime.ToString("MMM dd")</small><br />
                            <strong>@match.KickoffTime.ToString("HH:mm")</strong>
                        </td>
                        <td>
                            <span class="badge bg-info">@match.Stage</span>
                        </td>
                        <td>
                            <strong>@match.HomeTeam.Name</strong> vs <strong>@match.AwayTeam.Name</strong>
                        </td>
                        <td>@(match.Group?.Name ?? "-")</td>
                        <td>
                            @switch (match.Status)
                            {
                                case FinalWhistle.Domain.Enums.MatchStatus.Scheduled:
                                    <span class="badge bg-secondary">Scheduled</span>
                                    break;
                                case FinalWhistle.Domain.Enums.MatchStatus.Live:
                                    <span class="badge bg-success">Live</span>
                                    break;
                                case FinalWhistle.Domain.Enums.MatchStatus.Completed:
                                    <span class="badge bg-dark">Completed</span>
                                    break;
                            }
                        </td>
                        <td>
                            @if (match.Result != null)
                            {
                                <strong class="fs-5">@match.Result.HomeGoals - @match.Result.AwayGoals</strong>
                                @if (match.Result.HasExtraTime)
                                {
                                    <small class="text-muted">(AET)</small>
                                }
                                @if (match.Result.HasPenalties)
                                {
                                    <br /><small class="text-muted">Pens: @match.Result.PenaltiesHomeScore - @match.Result.PenaltiesAwayScore</small>
                                }
                            }
                            else
                            {
                                <span class="text-muted">No result</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Enter" asp-route-id="@match.Id" class="btn btn-sm btn-primary">
                                @(match.Result != null ? "Edit Result" : "Enter Result")
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-warning text-center">
            <p class="mb-0">No matches scheduled yet. <a asp-area="Admin" asp-controller="Matches" asp-action="Create">Schedule matches first</a></p>
        </div>
    }
</div>
