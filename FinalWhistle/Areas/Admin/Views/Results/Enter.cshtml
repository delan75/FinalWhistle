@model FinalWhistle.Domain.Entities.MatchResult
@{
    ViewData["Title"] = "Enter Match Result";
    var match = ViewBag.Match as FinalWhistle.Domain.Entities.Match;
}

<div class="container mt-4">
    <h2>Enter Match Result</h2>
    <hr />

    <div class="card mb-4">
        <div class="card-body">
            <h4 class="card-title">
                <strong>@match.HomeTeam.Name</strong> vs <strong>@match.AwayTeam.Name</strong>
            </h4>
            <p class="card-text">
                <span class="badge bg-info">@match.Stage</span>
                @if (match.Group != null)
                {
                    <span class="badge bg-secondary">@match.Group.Name</span>
                }
                <br />
                <small class="text-muted">@match.KickoffTime.ToString("MMMM dd, yyyy HH:mm")</small>
            </p>
        </div>
    </div>

    <form asp-action="Enter" asp-route-id="@match.Id" method="post">
        <div class="row">
            <div class="col-md-6">
                <h5 class="mb-3">Regular Time Score</h5>
                
                <div class="row">
                    <div class="col-6">
                        <div class="mb-3">
                            <label asp-for="HomeGoals" class="form-label">@match.HomeTeam.Name Goals</label>
                            <input asp-for="HomeGoals" class="form-control form-control-lg text-center" type="number" min="0" />
                            <span asp-validation-for="HomeGoals" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="mb-3">
                            <label asp-for="AwayGoals" class="form-label">@match.AwayTeam.Name Goals</label>
                            <input asp-for="AwayGoals" class="form-control form-control-lg text-center" type="number" min="0" />
                            <span asp-validation-for="AwayGoals" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <h5 class="mb-3">Additional Information</h5>
                
                <div class="mb-3 form-check">
                    <input asp-for="HasExtraTime" class="form-check-input" id="hasExtraTime" />
                    <label asp-for="HasExtraTime" class="form-check-label">Match went to Extra Time</label>
                </div>

                <div id="extraTimeSection" style="display: none;">
                    <div class="row">
                        <div class="col-6">
                            <div class="mb-3">
                                <label asp-for="ExtraTimeHomeGoals" class="form-label">ET Home Goals</label>
                                <input asp-for="ExtraTimeHomeGoals" class="form-control" type="number" min="0" />
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="mb-3">
                                <label asp-for="ExtraTimeAwayGoals" class="form-label">ET Away Goals</label>
                                <input asp-for="ExtraTimeAwayGoals" class="form-control" type="number" min="0" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="HasPenalties" class="form-check-input" id="hasPenalties" />
                    <label asp-for="HasPenalties" class="form-check-label">Match went to Penalties</label>
                </div>

                <div id="penaltiesSection" style="display: none;">
                    <div class="row">
                        <div class="col-6">
                            <div class="mb-3">
                                <label asp-for="PenaltiesHomeScore" class="form-label">Pens Home</label>
                                <input asp-for="PenaltiesHomeScore" class="form-control" type="number" min="0" />
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="mb-3">
                                <label asp-for="PenaltiesAwayScore" class="form-label">Pens Away</label>
                                <input asp-for="PenaltiesAwayScore" class="form-control" type="number" min="0" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="alert alert-info">
            <strong>Note:</strong> Saving this result will mark the match as Completed and lock all predictions.
        </div>

        <div class="mb-3">
            <button type="submit" class="btn btn-primary btn-lg">Save Result</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.getElementById('hasExtraTime').addEventListener('change', function() {
            document.getElementById('extraTimeSection').style.display = this.checked ? 'block' : 'none';
        });

        document.getElementById('hasPenalties').addEventListener('change', function() {
            document.getElementById('penaltiesSection').style.display = this.checked ? 'block' : 'none';
        });

        // Show sections if already checked (for edit mode)
        if (document.getElementById('hasExtraTime').checked) {
            document.getElementById('extraTimeSection').style.display = 'block';
        }
        if (document.getElementById('hasPenalties').checked) {
            document.getElementById('penaltiesSection').style.display = 'block';
        }
    </script>
}
