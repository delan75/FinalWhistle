@model FinalWhistle.Areas.Admin.Models.AdminTeamEditorViewModel
@{
    ViewData["Title"] = "Edit Team";
}

<div class="container mt-4">
    <h2>Edit Team</h2>
    <hr />

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="CreatedAt" />
        
        <div class="row">
            <div class="col-lg-7">
                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                    <small class="form-text text-muted">Changing the team name refreshes the country metadata preview.</small>
                </div>

                <div class="mb-3">
                    <label asp-for="FlagUrl" class="form-label">Flag URL</label>
                    <input asp-for="FlagUrl" class="form-control" placeholder="https://flagcdn.com/w40/us.png" />
                    <span asp-validation-for="FlagUrl" class="text-danger"></span>
                    <small class="form-text text-muted">Clear this field to let the helper save the suggested country flag.</small>
                </div>

                <div class="mb-3">
                    <label asp-for="GroupId" class="form-label">Group</label>
                    <select asp-for="GroupId" class="form-select" asp-items="ViewBag.Groups">
                        <option value="">-- Select Group --</option>
                    </select>
                    <span asp-validation-for="GroupId" class="text-danger"></span>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="IsVerified" class="form-check-input" />
                    <label asp-for="IsVerified" class="form-check-label"></label>
                </div>

                <div class="mb-3">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </div>

            <div class="col-lg-5">
                <div data-country-preview data-preview-url="@Url.Action("CountryPreview", "Teams", new { area = "Admin" })">
                    @await Html.PartialAsync("_CountryMetadataPreview", Model.CountryPreview)
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    @await Html.PartialAsync("_CountryMetadataScripts")
}
