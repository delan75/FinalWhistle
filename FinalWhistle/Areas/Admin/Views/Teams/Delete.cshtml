@model FinalWhistle.Domain.Entities.Team
@{
    ViewData["Title"] = "Delete Team";
}

<div class="container mt-4">
    <h2>Delete Team</h2>
    <hr />

    <div class="alert alert-danger">
        <h4>Are you sure you want to delete this team?</h4>
        <p>This action cannot be undone.</p>
    </div>

    <div class="card">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(Model.FlagUrl))
                    {
                        <img src="@Model.FlagUrl" alt="@Model.Name" style="width: 32px; height: 21px; margin-right: 8px;" />
                    }
                    @Model.Name
                </dd>

                <dt class="col-sm-3">Slug</dt>
                <dd class="col-sm-9">@Model.Slug</dd>

                <dt class="col-sm-3">Group</dt>
                <dd class="col-sm-9">@(Model.Group?.Name ?? "Not Assigned")</dd>

                <dt class="col-sm-3">Verified</dt>
                <dd class="col-sm-9">
                    @if (Model.IsVerified)
                    {
                        <span class="badge bg-success">Yes</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">No</span>
                    }
                </dd>

                <dt class="col-sm-3">Created</dt>
                <dd class="col-sm-9">@Model.CreatedAt.ToString("MMM dd, yyyy")</dd>
            </dl>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">Delete Team</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>
